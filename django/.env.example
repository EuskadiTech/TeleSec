# TeleSec Django – environment variables
# Copy to .env and fill in your values before running.

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-jwt-secret-too

# ── Instance ──────────────────────────────────────────────────────────────────
# Shared password for the persona-selection login screen.
# Leave empty to disable password protection (development only).
INSTANCE_PASSWORD=
INSTANCE_NAME=TeleSec

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=/data/telesec.db

# ── Network ───────────────────────────────────────────────────────────────────
PORT=8000
ALLOWED_HOSTS=*
CORS_ORIGINS=*

# ── Licensing (Keygen.sh) ─────────────────────────────────────────────────────
# Your public Keygen.sh account UUID.  Required only for premium module packages.
# Sign up at https://keygen.sh – the free Community tier is enough to get started.
KEYGEN_ACCOUNT_ID=

# ── Development ───────────────────────────────────────────────────────────────
DJANGO_DEBUG=false
