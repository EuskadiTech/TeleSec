# Axia4 (prev. TeleSec) Backend – environment variables
# Copy this file to .env and fill in production values.

# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_DEBUG=false

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-too

# SQLite database file path
DATABASE_PATH=telesec.db

# Allowed CORS origins (comma-separated or '*' for any)
CORS_ORIGINS=*

# Server port
PORT=5000
